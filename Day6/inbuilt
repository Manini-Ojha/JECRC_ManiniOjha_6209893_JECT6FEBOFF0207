##functions for set

#1.add
seet={1,2,3,1.5}
seet.add(1)#no effect since element already exists
seet.add(4)#added in the set
#throws error if we try to add a mutable collection

#2.remove
seet={1,2,True,False,0,10,3+9j}
seet.remove(10)#removes element form set, if it doesn't exist, keyError is raised


#3.discard
seet.discard(3)#removes element from set, if not present, no error is thrown

#4.pop:Randomly eliminates the values single value at a time
seet.pop()#doesn't take any arguments

#5.clear
#reemoves elements from set

#6.union
set1={1,2,3}
seet.union(set1)#takes the union of two sets
#returns a new set with the elements from the set and all others (other sets too)

#7.intersection
seet.intersection(set1)#takes intersection of two sets

#8.difference
#returns uncommon elements from the first set
set1.difference(seet)#will return set1={1,2,3}
seet.difference(set1)#will return seet=set()

#9.symmetric_difference
#returns a new set with elements in either the set or others but not both
set1.symmetric_difference(seet)#returns {1,2,3}
seet.symmetric_difference(set1)#returns {1,2,3}
set2={2,3,4}
set1.symmetric_difference(set2)#returns {1,4}
set1.symmetric_difference(set1)#returns set() which is an empty set


